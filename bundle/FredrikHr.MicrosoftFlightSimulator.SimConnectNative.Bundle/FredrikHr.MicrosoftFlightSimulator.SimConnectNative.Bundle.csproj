<?xml version="1.0" encoding="UTF-8"?>
<Project>

  <PropertyGroup>
    <Configurations>Release</Configurations>
    <DefaultProjectConfiguration>Release</DefaultProjectConfiguration>
    <Platforms>x64</Platforms>
    <DefaultProjectPlatform>x64</DefaultProjectPlatform>
  </PropertyGroup>

  <Import Sdk="Microsoft.Build.NoTargets" Project="Sdk.props" />

  <PropertyGroup>
    <Description>No description provided.</Description>
  </PropertyGroup>

  <PropertyGroup>
    <!-- TFM is stripped when packing, use a TFM that makes the compiler happy -->
    <TargetFramework>netstandard2.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <AppendPlatformToOutputPath>false</AppendPlatformToOutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
  </PropertyGroup>
  <PropertyGroup>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <IncludeSymbols>false</IncludeSymbols>
    <NoWarn>$(NoWarn);NU5128</NoWarn>
    <IncludeBuildOutput>true</IncludeBuildOutput>
    <BuildOutputTargetFolder>runtimes\$(RuntimeIdentifier)\</BuildOutputTargetFolder>
  </PropertyGroup>
  <PropertyGroup>
    <Version>$(MsfsSdkVersion)</Version>
  </PropertyGroup>

  <ItemGroup>
    <BuildOutputInPackage Include="$(MsfsSdkPath)SimConnect SDK\lib\SimConnect.dll">
      <TargetFramework>native</TargetFramework>
    </BuildOutputInPackage>
  </ItemGroup>
  <ItemGroup>
    <None Include="$(MsfsSdkPath)\Licenses\*.*">
      <Pack>true</Pack>
      <PackagePath></PackagePath>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FredrikHr.NupkgMSBuild.StripNuspecTfm">
      <ProjectReference>..\..\.submodules\fredrikhr\nuget-msbuild-extensions\build\FredrikHr.NupkgMSBuild.StripNuspecTfm\FredrikHr.NupkgMSBuild.StripNuspecTfm.csproj</ProjectReference>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>
  <PropertyGroup>
    <GenerateNuspecStripTargetFrameworkAttributes>true</GenerateNuspecStripTargetFrameworkAttributes>
  </PropertyGroup>

  <Import Sdk="Microsoft.Build.NoTargets" Project="Sdk.targets" />
  <Import Project="..\BundleBuildOutput.targets" />

</Project>
